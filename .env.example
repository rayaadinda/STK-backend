APP_NAME=stk-backend
APP_ENV=development
APP_PORT=8080
APP_CORS_ALLOW_ORIGIN=http://localhost:3000
APP_READ_TIMEOUT_SECONDS=15
APP_WRITE_TIMEOUT_SECONDS=15
APP_SHUTDOWN_TIMEOUT_SECONDS=10

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=stk_backend
DB_SSLMODE=disable
DB_TIMEZONE=UTC
DB_MAX_IDLE_CONNS=10
DB_MAX_OPEN_CONNS=50
DB_CONN_MAX_LIFETIME_MINUTES=30
